# ─────────────────────────────────────────────────────────────
# Produccion (DigitalOcean droplet)
# Copiar a .env en la raiz del proyecto y rellenar:
#   cp .env.prod.example .env
# Compose lo lee automaticamente para interpolar ${VAR}.
# NO commitear el .env real (ya esta en .gitignore).
# ─────────────────────────────────────────────────────────────

# URL PUBLICA de la API — la usa el BROWSER, se hornea en el build del frontend.
# Debe ser la IP o dominio del droplet, NO localhost.
#   Por IP:      http://164.92.xx.xx:5000
#   Por dominio: https://api.tu-dominio.com
PUBLIC_API_URL=http://CAMBIAR_IP_DROPLET:5000
VITE_API_TIMEOUT=30000

# Secreto JWT — generar uno fuerte:  openssl rand -hex 32
JWT_SECRET_KEY=CAMBIAR_POR_SECRETO_FUERTE
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
